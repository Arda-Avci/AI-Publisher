{
  "name": "ai-publisher",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx watch --ignore \"videolar/**\" --ignore \"uploads/**\" src/server.ts",
    "dev:frontend": "npm --prefix client run dev",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "node dist/server.js",
    "start:frontend": "npm --prefix client run preview",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint src --quiet",
    "lint": "eslint src",
    "eslint:fix": "eslint src --fix",
    "build": "tsc",
    "setup-ngrok": "node scripts/setup-ngrok.js",
    "test": "npx vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "format:check": "prettier --check \"src/**/*.ts\" \"client/src/**/*.tsx\"",
    "format:write": "prettier --write \"src/**/*.ts\" \"client/src/**/*.tsx\"",
    "test:browser": "tsx scripts/run-e2e.ts",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "overrides": {
    "axios": "^1.16.1",
    "ws": "^8.21.0",
    "playwright": "^1.60.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.82",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/openai": "^3.0.68",
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@crewai-ts/core": "^0.2.3",
    "@crewai-ts/gemini": "^0.2.3",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.5",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-prometheus": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-amqplib": "^0.66.0",
    "@opentelemetry/instrumentation-ioredis": "^0.67.0",
    "@opentelemetry/instrumentation-pg": "^0.71.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "ai": "^6.0.193",
    "amqplib": "^2.0.1",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.19.0",
    "fs-extra": "^11.3.5",
    "ioredis": "^5.11.1",
    "iyzipay": "^2.0.67",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "pino": "^9.0.0",
    "pino-http": "^11.0.0",
    "playwright": "^1.60.0",
    "ws": "^8.21.0",
    "youtube-transcript": "^1.2.1",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/fs-extra": "^11.0.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@types/yt-search": "^2.10.3",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
